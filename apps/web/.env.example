# Mapbox access token — required for map rendering
# Get one at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# National metro vector tiles (PMTiles). Omit to use GeoJSON fallback (58 metros).
# Build tiles: pnpm --filter @cineborough/data build:us-metro-tiles
NEXT_PUBLIC_METRO_TILES_URL=/tiles/us-metros.pmtiles

# On-demand metro shard API. fetchMetroShard() uses bundled shards first, then
# local GET /api/v1/metros/{cbsa}/geojson when unset. Override for external API:
# NEXT_PUBLIC_METRO_API_BASE_URL=https://api.example.com/v1
